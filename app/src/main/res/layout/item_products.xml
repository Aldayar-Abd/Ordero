<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="184dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="20dp"
    android:layout_marginEnd="12dp"
    android:layout_marginVertical="12dp"
    android:elevation="12dp"
    android:layout_height="311dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:scaleType="centerCrop"
            android:src="@drawable/prod"
            android:id="@+id/img_product"
            android:layout_width="184dp"
            android:layout_height="201dp"/>
        <TextView
            android:layout_marginTop="4dp"
            android:id="@+id/txt_price"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:text="350с"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/img_product"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:layout_marginTop="4dp"
            android:id="@+id/txt_name"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:text="Футболка из хлопка"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:layout_marginTop="4dp"
            android:id="@+id/txt_category"
            android:textSize="14sp"
            android:text="Одежда"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

            <ImageView
                android:layout_marginBottom="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:id="@+id/img_favorite"
                android:layout_marginTop="4dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_heart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            
            <TextView
                app:layout_constraintBottom_toBottomOf="@id/img_favorite"
                app:layout_constraintStart_toEndOf="@id/img_favorite"
                app:layout_constraintTop_toTopOf="@id/img_favorite"
                android:layout_weight="1"
                android:id="@+id/txt_name_shop"
                android:layout_marginStart="30dp"
                android:layout_gravity="center"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fashion home"/>

        <androidx.cardview.widget.CardView
            android:layout_marginEnd="10dp"
            android:layout_marginStart="4dp"
            app:layout_constraintBottom_toBottomOf="@id/txt_name_shop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/txt_name_shop"
            app:cardCornerRadius="50dp"
            android:layout_width="25dp"
            android:layout_height="25dp">
            <ImageView
                android:scaleType="centerCrop"
                android:id="@+id/img_profile"
                android:layout_gravity="center"
                android:src="@drawable/ic_prof1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>