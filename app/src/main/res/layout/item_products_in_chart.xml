<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="16dp"
    android:layout_marginVertical="10dp"
    android:elevation="12dp"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.cardview.widget.CardView
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:id="@+id/img_holder"
            android:layout_width="130dp"
            android:layout_height="160dp"
            app:cardCornerRadius="16dp">

            <ImageView
                android:id="@+id/img_product"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/prod" />
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_marginStart="10dp"
            android:id="@+id/top_container"
            app:layout_constraintEnd_toStartOf="@id/cb_select_prod"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/img_holder"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:layout_marginTop="8dp"
                android:id="@+id/txt_name"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:gravity="start"
                android:text="Футболка из хлопка"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:layout_marginTop="9dp"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:text="Размер:"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/txt_size"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:text="M"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:layout_marginVertical="9dp"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:text="Расцветка:"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/txt_color"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:text="Белый"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:text="Выбранное коль-во:"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/txt_selected_count"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:text="2000шт"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatCheckBox
            android:id="@+id/cb_select_prod"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:button="@drawable/selector_checkbox_custom"
            android:background="@null"
            android:text=""
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            app:buttonTint="@null"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:layout_marginBottom="10dp"
            android:id="@+id/img_shop_prof"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_prof1"
            android:elevation="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/top_container"
            />
        <TextView
            android:layout_marginStart="6dp"
            app:layout_constraintTop_toTopOf="@id/img_shop_prof"
            app:layout_constraintBottom_toBottomOf="@id/img_shop_prof"
            app:layout_constraintStart_toEndOf="@id/img_shop_prof"
            android:text="Fashion home"
            android:textSize="10sp"
            android:textColor="@color/gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.cardview.widget.CardView>