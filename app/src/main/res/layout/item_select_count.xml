<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="24dp"
    android:elevation="12dp"
    android:layout_marginVertical="20dp"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="130dp">

        <ImageView
            android:src="@drawable/red_shirt"
            android:id="@+id/img_color"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="120dp"
            android:scaleType="centerCrop"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:id="@+id/cont_info"
            app:layout_constraintStart_toEndOf="@id/img_color"
            app:layout_constraintTop_toTopOf="@id/img_color"
            android:layout_marginTop="11dp"
            android:layout_marginStart="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/size_container"
                android:layout_marginVertical="6dp"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textColor="@color/gray"
                    android:text="Размер:"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:layout_marginStart="5dp"
                    android:id="@+id/txt_size"
                    android:textColor="@color/black"
                    android:text="M"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/txt_rasvetka"
                    android:textColor="@color/gray"
                    android:text="Расцветка:"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/txt_color"
                    android:layout_marginStart="5dp"
                    android:textColor="@color/black"
                    android:text="Красный"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Доступное кол-во:"
                    android:textColor="@color/gray"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txt_available_count"
                    android:layout_marginStart="5dp"
                    android:textColor="@color/black"
                    android:text="1000 шт"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/txt_choose_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Выбранное кол-во:"
                    android:textColor="@color/main_color"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txt_selected_count"
                    android:layout_marginStart="5dp"
                    android:textColor="@color/black"
                    android:text=""
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>